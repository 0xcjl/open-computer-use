{
	"name": "@0xcjl/open-computer-use",
	"version": "0.1.0",
	"description": "A state-scoped, policy-gated macOS Computer Use runtime for any MCP-capable agent.",
	"type": "module",
	"keywords": [
		"computer-use",
		"macos",
		"desktop-automation",
		"accessibility",
		"mcp",
		"hermes",
		"openclaw"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/0xcjl/open-computer-use.git"
	},
	"bugs": {
		"url": "https://github.com/0xcjl/open-computer-use/issues"
	},
	"homepage": "https://github.com/0xcjl/open-computer-use#readme",
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"src",
		"bin",
		"scripts/build-native.mjs",
		"scripts/setup-helper.mjs",
		"scripts/build-fixture.mjs",
		"fixtures",
		"native/macos",
		"prebuilt/macos",
		"README.md",
		"LICENSE",
		"NOTICE",
		"skills"
	],
	"bin": {
		"ocu": "bin/ocu.mjs"
	},
	"exports": {
		".": "./src/index.ts",
		"./mcp": "./src/mcp.ts"
	},
	"scripts": {
		"typecheck": "tsc -p tsconfig.json",
		"test:schema": "node scripts/check-tool-schemas.mjs",
		"test:invariants": "node scripts/check-invariants.mjs",
		"test:lifecycle": "node node_modules/tsx/dist/cli.mjs scripts/check-session-lifecycle.mjs",
		"test:runtime": "node node_modules/tsx/dist/cli.mjs scripts/check-runtime-concurrency.mjs",
		"test:commits": "node scripts/check-commit-messages.mjs",
		"test:platform": "node node_modules/tsx/dist/cli.mjs scripts/check-platform-windows.mjs",
		"test:windows-scripts": "node scripts/check-windows-build-scripts.mjs",
		"test:signing": "node scripts/check-local-signing.mjs",
		"test:policy": "node node_modules/tsx/dist/cli.mjs tests/policy.test.ts",
		"test:mcp": "node node_modules/tsx/dist/cli.mjs tests/mcp.test.ts",
		"test": "npm run typecheck && npm run test:policy && npm run test:mcp && npm run test:schema && npm run test:lifecycle && npm run test:runtime && npm run test:invariants && npm run test:signing",
		"build:native": "node scripts/build-native.mjs",
		"build:fixture": "node scripts/build-fixture.mjs",
		"mcp": "node bin/ocu.mjs mcp",
		"doctor": "node bin/ocu.mjs doctor"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"tsx": "^4.23.1",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	}
}
